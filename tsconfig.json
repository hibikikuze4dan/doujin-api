{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["esnext"],
    "types": ["node"],

    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": false,
    "rootDir": ".",
    "skipLibCheck": true,

    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.ts",
    "utils/archives/createThumbnailForArchive.ts",
    "utils/configuration/index.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage", ".yarn", "public"]
}
